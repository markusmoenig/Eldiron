Region "cellar" {
  name = "Source Cellar"
  default = wall.stone

  terrain """
  #########
  #.......#
  #..h.O..#
  #...@...#
  #....b..#
  #########
  """
}

Screen "play" {
  name = "Play"

  widget "Game" {
    role = "game"
    x = 0
    y = 0
    width = 80
    height = 24

    data {
      [ui]
      role = "game"
      grid_size = 40

      [camera]
      type = "2d"

      [camera_safe_area]
      right = 34
    }
  }

  widget "Sidebar" {
    role = "deco"
    x = 46
    y = 0
    width = 34
    height = 24

    data {
      [ui]
      role = "deco"
      color = "#0000006f"
      border_color = "#444444"
      border_size = 0
    }
  }

  widget "Stats" {
    role = "text"
    x = 48
    y = 2
    width = 30
    height = 7

    data {
      [ui]
      role = "text"
      text = """
{PLAYER.CLASS}
LVL {PLAYER.LEVEL}  EXP {PLAYER.EXP}
HP {PLAYER.HP}/{PLAYER.MAX_HP}
MP {PLAYER.MP}/{PLAYER.MAX_MP}
STR {PLAYER.STR}  DEX {PLAYER.DEX}
INT {PLAYER.INT}  WIS {PLAYER.WIS}
"""
    }
  }

  widget "Messages" {
    role = "messages"
    x = 48
    y = 10
    width = 30
    height = 13

    data {
      [ui]
      role = "messages"
      font_size = 18.0
      background_color = "#00000099"
      default = "#ffffff"
      warning = "#ff8888"
      severe = "#ff6666"
      success = "#88ff88"
      handles = ["messages", "dialogs", "multiple_choice", "offer_inventory"]
    }
  }
}
