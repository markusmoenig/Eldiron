      "module": null,
      "source": "fn event(event, value) {\n        if event == \"startup\" {\n            random_walk( 1.0,  1.0,  4);\n            set_proximity_tracking( true,  4);\n            set_attr( \"target\",  \"\");\n        }\n        if event == \"proximity_warning\" {\n            let hostile = is_hostile( value);\n            if hostile == 1 {\n                if target() == \"\" {\n                    set_target( value);\n                }\n                follow_attack( value,  0.6);\n            }\n        }\n        if event == \"engagement_over\" {\n            clear_target();\n            random_walk( 1.0,  1.0,  4);\n            set_proximity_tracking( false,  5.0);\n        }\n        if event == \"kill\" {\n            set_proximity_tracking( false,  5.0);\n            random_walk( 1.0,  1.0,  4);\n            clear_target();\n        }\n        if event == \"arrived\" {\n            set_proximity_tracking( true,  5.0);\n            random_walk( 1.0,  1.0,  4);\n        }\n        if event == \"death\" {\n            drop_items( \"\");\n            set_attr( \"visible\",  false);\n        }\n        if event == \"damaged\" {\n            let amount = value.amount;\n            message( value.attacker_id,  \"You hit the Orc for \" + amount + \" damage\",  \"\");\n        }\n    }",
      "source_debug": "fn event(event, value) {\n        if event == \"startup\" {\n            random_walk( 1.0,  1.0,  4);\n            set_proximity_tracking( true,  4);\n            set_attr( \"target\",  \"\");\n        }\n        if event == \"proximity_warning\" {\n            let hostile = is_hostile( value);\n            if hostile == 1 {\n                if target() == \"\" {\n                    set_target( value);\n                }\n                follow_attack( value,  0.6);\n            }\n        }\n        if event == \"engagement_over\" {\n            clear_target();\n            random_walk( 1.0,  1.0,  4);\n            set_proximity_tracking( false,  5.0);\n        }\n        if event == \"kill\" {\n            set_proximity_tracking( false,  5.0);\n            random_walk( 1.0,  1.0,  4);\n            clear_target();\n        }\n        if event == \"arrived\" {\n            set_proximity_tracking( true,  5.0);\n            random_walk( 1.0,  1.0,  4);\n        }\n        if event == \"death\" {\n            drop_items( \"\");\n            set_attr( \"visible\",  false);\n        }\n        if event == \"damaged\" {\n            let amount = value.amount;\n            message( value.attacker_id,  \"You hit the Orc for \" + amount + \" damage\",  \"\");\n        }\n    }",
