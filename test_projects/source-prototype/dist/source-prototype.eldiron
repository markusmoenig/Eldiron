  "config": "[ruleset]\nid = \"eldiron.official\"\nversion = \"1.0.0\"\nschema_version = \"1\"\nsource = \"official\"\nupdate_policy = \"compatible\"\n\n[game]\nstart_region = \"cellar\"\nstart_screen = \"play\"\nterminal_mode = \"roguelike\"\nsimulation_mode = \"hybrid\"\nturn_timeout_ms = 600\nauto_create_player = true\ncollision_mode = \"tile\"\n\n[viewport]\nwidth = 80\nheight = 24\ngrid_size = 40\nunit = \"cell\"\nresize = \"fit\"\n\n[terminal]\ntext_updates = true",
