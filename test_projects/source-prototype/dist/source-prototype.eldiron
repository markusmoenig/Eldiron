      "module": null,
      "source": "fn event(event, value) {\n    if event == \"active\" {\n        set_emit_light(value);\n        if value == true {\n            set_tile(\"f76473d1-70f6-4649-8b0d-cbac627f93d8\");\n        } else {\n            set_tile(\"05ab6adc-1631-4ed2-9857-f85820a7f1ad\");\n        }\n    }\n    if event == \"intent\" {\n        let intent = value.string;\n        if intent == \"use\" {\n            if value.distance > 2 {\n                message(value.subject_id, \"{system.too_far_away}\", \"warning\");\n            } else {\n                toggle_attr(\"active\");\n                block_events(1, \"intent\");\n            }\n        }\n    }\n}",
      "source_debug": "",
      "data": "tile_id = \"05ab6adc-1631-4ed2-9857-f85820a7f1ad\"\n\n[attributes]\naccent_color_index = 23\nactive = false\nblade_color_index = 10\nblocking = false\ncategory = \"utility\"\ncondition = 100\ndescription = \"A simple hand torch with an iron bracket and a rag-wrapped head.\"\ndurability_amount = 10\ndurability_drain = \"condition\"\ndurability_on_empty = \"destroy\"\ndurability_per_game_minutes = 60\ndurability_when = \"active\"\ngrip_color_index = 10\nhighlight_color_index = 14\nicon = \"torch\"\nmonetary = false\nname = \"Torch\"\noff_tile_id = \"05ab6adc-1631-4ed2-9857-f85820a7f1ad\"\non_look = \"A simple hand torch with an iron bracket and a rag-wrapped head.\"\non_look_off = \"An unlit torch rests here, cold and dark.\"\non_look_on = \"A lit torch burns with a wavering flame, pushing back the shadows.\"\non_tile_id = \"f76473d1-70f6-4649-8b0d-cbac627f93d8\"\nquality = 100\nradius = 0.5\nrarity = \"common\"\nruleset_id = \"torch\"\nruleset_kind = \"tool\"\nruleset_path = \"items.tools.torch\"\nslot = \"tool\"\nstatic = false\ntakeable = false\nvisible = true\nvisual_template = \"torch_standing\"\nvisual_template_height = 24\nvisual_template_pixels = [\"........................\", \"..........HHHH..........\", \".........HHBBH..........\", \".........HBBBB..........\", \"..........BBBB..........\", \".........GBBBH..........\", \"..........AAA...........\", \".........AAAAA..........\", \"..........AAA...........\", \"..........AAA...........\", \"..........AAA...........\", \"..........AAA...........\", \"..........AAA...........\", \"..........AAA...........\", \"..........AAA...........\", \"..........AAA...........\", \"..........AAA...........\", \"..........AAA...........\", \"..........AAA...........\", \".........GAAAG..........\", \"........GGAAAGG.........\", \"........................\", \"........................\", \"........................\"]\nvisual_template_width = 24\nworth = 10\n\n[light]\nflicker = 0.4\nrange = 3.0\nstrength = 5.0\n\n[ruleset.durability]\namount = 10\ndrain = \"condition\"\non_empty = \"destroy\"\nper_game_minutes = 60\nwhen = \"active\"\n",
      "authoring": "description = \"\"\"\nA simple hand torch with an iron bracket and a rag-wrapped head.\n\"\"\"\ntitle = \"Torch\"\n\n[state.off]\ndescription = \"\"\"\nAn unlit torch rests here, cold and dark.\n\"\"\"\non_use = \"You light the torch.\"\n\n[state.on]\ndescription = \"\"\"\nA lit torch burns with a wavering flame, pushing back the shadows.\n\"\"\"\non_use = \"You extinguish the torch.\"\n",
      "position": {
        "x": 0.0,
        "y": 0.0,
        "z": 0.0
      },
      "item_id": "829007a2-fed6-4dce-b076-a72db79785a8"
    },
