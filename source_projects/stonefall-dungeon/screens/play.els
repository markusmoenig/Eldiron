  widget "Cast Spell" {
    role = "button"
    x = 736
    y = 444
    width = 98
    height = 24

    data {
      [ui]
      role = "button"
      command = "intent.spell:{UI.spell.runes}"
      border_size = 1
      border_color = "#d7bb57"
      background_color = "#322a0dcc"
      show_icon = false
      label = "CAST"
      font_size = 12.0
      color = "#fff2ba"
    }
  }

  widget "Clear Spell" {
    role = "button"
    x = 846
    y = 444
    width = 98
    height = 24

    data {
      [ui]
      role = "button"
      bind = "spell.runes"
      value = ""
      border_size = 1
      border_color = "#5c6470"
      background_color = "#10131acc"
      show_icon = false
      label = "CLR"
      font_size = 12.0
      color = "#d9fbff"
