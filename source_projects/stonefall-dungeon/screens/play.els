  }

  widget "Magic Label" {
    role = "text"
    x = 736
    y = 320
    width = 208
    height = 20

    data {
      [ui]
      role = "text"
      font_size = 12.0
      color = "#2fd5df"
      text = """
MAGIC
"""
    }
  }

  widget "Rune Queue Back" {
    role = "deco"
    x = 736
    y = 340
    width = 208
    height = 28

    data {
      [ui]
      role = "deco"
      color = "#050b10cc"
      border_size = 1
      border_color = "#2f7077"
    }
  }

  widget "Rune Queue" {
    role = "text"
    x = 746
    y = 345
    width = 188
    height = 18

    data {
      [ui]
      role = "text"
      font_size = 13.0
      color = "#e5fbff"
      align = "center"
      text = """
{UI.spell.runes}
"""
    }
  }

  widget "Rune Lo" {
    role = "button"
    x = 736
    y = 370
    width = 62
    height = 30

    data {
      [ui]
      role = "button"
      bind = "spell.runes"
      value = "LO"
      append = true
      max_parts = 4
      border_size = 1
      border_color = "#45cbd0"
      background_color = "#09171dcc"
      show_icon = false
      label = "LO"
      font_size = 13.0
      color = "#d9fbff"
    }
  }

  widget "Rune Vi" {
    role = "button"
    x = 809
    y = 370
