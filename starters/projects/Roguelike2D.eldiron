exit\",  id());\n        }\n    }\n}\n\n","source_debug":"fn event(event, value) {\n    if event == \"startup\" {\n        mark_debug_header(\"startup\");\n        set_debug_loc(\"startup\", 0, 1); set_player_camera( \"2d_grid\");\n    }\n    if event == \"death\" {\n        mark_debug_header(\"death\");\n        set_debug_loc(\"death\", 0, 0); drop_items( \"\");\n        set_debug_loc(\"death\", 0, 1); set_attr( \"HP\",  8);\n        set_debug_loc(\"death\", 0, 2); set_attr( \"mode\",  \"active\");\n        set_debug_loc(\"death\", 0, 3); set_attr( \"visible\",  true);\n        set_debug_loc(\"death\", 0, 4); teleport( \"entrance\",  \"Dungeon\");\n        set_debug_loc(\"death\", 0, 5); message( id(),  \"You died. Try again!\",  \"severe\");\n    }\n    if event == \"intent\" && value == \"attack\" {\n        mark_debug_header(\"intent: attack\");\n        set_debug_loc(\"intent: attack\", 2, 0); let damage = random( 3,  5);\n        set_debug_value(\"intent: attack\", 0, 0, damage);\n        set_debug_loc(\"intent: attack\", 0, 1); deal_damage( value.subject_id,  damage);\n    }\n    if event == \"intent\" && value == \"take\" {\n        mark_debug_header(\"intent: take\");\n        set_debug_loc(\"intent: take\", 0, 0); take( value.subject_id);\n    }\n    if event == \"intent\" && value == \"drop\" {\n        mark_debug_header(\"intent: drop\");\n        set_debug_loc(\"intent: drop\", 0, 0); drop( value.subject_id);\n    }\n    if event == \"kill\" {\n        mark_debug_header(\"kill\");\n        set_debug_loc(\"kill\", 2, 0); let name = get_attr_of( value,  \"name\");\n        set_debug_value(\"kill\", 0, 0, name);\n        set_debug_loc(\"kill\", 0, 1); message( id(),   \"You kill the \" + name,  \"success\");\n    }\n    if event == \"entered\" {\n        mark_debug_header(\"entered\");\n        let __cgfx_cond_0_0 = value == \"Dungeon Entrance\";\n        set_debug_condition(\"entered\", 0, 0, __cgfx_cond_0_0);\n        if __cgfx_cond_0_0 {\n            set_debug_loc(\"entered\", 0, 1); teleport( \"entrance\",  \"Dungeon\");\n        }\n        let __cgfx_cond_0_2 = value == \"exit\";\n        set_debug_condition(\"entered\", 0, 2, __cgfx_cond_0_2);\n        if __cgfx_cond_0_2 {\n            let depth = region.dungeon.depth + 1;\n            set_debug_value(\"entered\", 0, 3, depth);\n            region.dungeon.depth = depth;\n            region.procedural.room_count = 6 + depth;\n            region.procedural.characters.skeleton.percentage = 25 + depth * 6;\n            set_debug_loc(\"entered\", 0, 7); world_event( \"dungeon_exit\",  id());\n        }\n    }\n}\n\n","data":"[attributes]\n\ntile_id = \"da0ecee1-5171-4195-a396-9503a364edc6\"\n\nrace = \"Human\"\nclass = \"Fighter\"\n\nvisible = true\nplayer = true\nwealth = 1\n\nSTR = 2\nDEX = 1\nHP = 8\nALIGNMENT = 1\n\ninventory_slots = 6\n\n[intent_distance]\ndefault = 2\n\n[intents.attack]\nallowed = \"target.ALIGNMENT < 0\"\ndeny_message = \"{system.cant_do_that}\"\ncooldown = 2\n\n[input]\nw = \"action(forward)\"\na = \"action(left)\"\ns = \"action(backward)\"\nd = \"action(right)\"\nu = \"intent(use)\"\nt = \"intent(attack)\"\nk = \"intent(take)\"\nl = \"intent(look)\"\n","authoring":"title = \"Your ship captain\"\ndescription = \"\"\"\nA seasoned traveler in simple gear, ready to defend the hideout and make a life here.\n\"\"\"\n\n[mode.active]\ndescription = \"\"\"\nYou look travel-worn but capable, with just enough supplies to get by.\n\"\"\"\n\n[mode.dead]\ndescription = \"\"\"\nYour journey ends here, still and silent.\n\"\"\"\n","preview_rigging":"# Editor-only preview. Runtime equipment/animation comes from server scripts.\n#\nanimation = \"Idle\"\nperspective = \"Front\"\nplay = true\nspeed = 1.0\n\n[slots]\n# main_hand = \"Item Name\"\n# off_hand = \"Item Name\"\n","position":{"x":0.0,"y":0.0,"z":0.0},"orientation":{"x":1.0,"y":0.0},"character_id":"004c351c-ab85-462f-9ce2-66e3adbcf953"},"d6dfc870-6c0f-4e51-b5aa-5802eb403c2d":{"id":"d6dfc870-6c0f-4e51-