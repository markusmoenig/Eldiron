, 0, 3); set_attr( \"target\",  \"\");\n    }\n    if event == \"proximity_warning\" {\n        mark_debug_header(\"proximity_warning\");\n        set_debug_loc(\"proximity_warning\", 2, 0); let alignment = get_attr_of( value,  \"ALIGNMENT\");\n        set_debug_value(\"proximity_warning\", 0, 0, alignment);\n        let __cgfx_cond_0_1 = alignment > 0;\n        set_debug_condition(\"proximity_warning\", 0, 1, __cgfx_cond_0_1);\n        if __cgfx_cond_0_1 {\n            set_debug_loc(\"proximity_warning\", 1, 2); if target() == \"\" {\n                set_debug_loc(\"proximity_warning\", 0, 3); set_target( value);\n            }\n            set_debug_loc(\"proximity_warning\", 0, 4); follow_attack( value,  0.6);\n        }\n    }\n    if event == \"engagement_over\" {\n        mark_debug_header(\"engagement_over\");\n        set_debug_loc(\"engagement_over\", 0, 0); clear_target();\n        set_debug_loc(\"engagement_over\", 0, 1); set_proximity_tracking( true,  4.0);\n        set_debug_loc(\"engagement_over\", 0, 2); random_walk( 1.0,  1.0,  1);\n    }\n    if event == \"kill\" {\n        mark_debug_header(\"kill\");\n        set_debug_loc(\"kill\", 0, 0); clear_target();\n        set_debug_loc(\"kill\", 0, 1); set_proximity_tracking( true,  4.0);\n        set_debug_loc(\"kill\", 0, 2); random_walk( 1.0,  1.0,  1);\n    }\n    if event == \"death\" {\n        mark_debug_header(\"death\");\n        set_debug_loc(\"death\", 0, 0); drop_items( \"\");\n        set_debug_loc(\"death\", 0, 1); set_attr( \"visible\",  false);\n    }\n}\n\n","data":"[attributes]\ntile_id = \"9dc56d24-dc02-4da5-836f-9742d0a32010\"\n\nrace = \"Skeleton\"\nclass = \"Fighter\"\n\nHP = 8\nALIGNMENT = -1\n\nvisible = true\nradius = 0.5\n\ninventory_slots = 1\nwealth = 1","authoring":"title = \"Orc\"\ndescription = \"\"\"\nA surly orc prowls the garden, spoiling the peace with brute menace.\n\"\"\"\n\n[mode.active]\ndescription = \"\"\"\nThe orc is tense and ready for violence, watching for any 