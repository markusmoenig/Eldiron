,[[3,2],{"x":305,"y":139,"width":30,"height":50,"buffer_x":305,"buffer_y":139}],[[4,1],{"x":204,"y":89,"width":30,"height":50,"buffer_x":204,"buffer_y":89}]],"row_indents":[[7,0],[3,1],[1,0],[5,1],[6,1],[4,0],[2,1]]}}},"player":false,"view_name":"DockVisualScripting","filter_text":""},"source":"fn event(event, value) {\n    if event == \"startup\" {\n    }\n    if event == \"bumped_by_entity\" {\n        let items = inventory_items_of( value,  \"Golden Key\");\n        if items.count > 0 {\n            set_attr( \"visible\",  false);\n            set_attr( \"blocking\",  false);\n            notify_in( 2,  \"close_gate\");\n        }\n        else{\n            message( value,  \"You need a golden key!\",  \"warning\");\n        }\n    }\n    if event == \"close_gate\" {\n        let entities = entities_in_radius();\n        if entities.count == 0 {\n            set_attr( \"visible\",  true);\n            set_attr( \"blocking\",  true);\n        }\n        else{\n            notify_in( 2,  \"close_gate\");\n        }\n    }\n}\n\n","source_debug":"fn event(event, value) {\n    if event == \"startup\" {\n        mark_debug_header(\"startup\");\n    }\n    if event == \"bumped_by_entity\" {\n        mark_debug_header(\"bumped_by_entity\");\n        set_debug_loc(\"bumped_by_entity\", 2, 0); let items = inventory_items_of( value,  \"Golden Key\");\n        set_debug_value(\"bumped_by_entity\", 0, 0, items);\n        let __cgfx_cond_0_1 = items.count > 0;\n        set_debug_condition(\"bumped_by_entity\", 0, 1, __cgfx_cond_0_1);\n        if __cgfx_cond_0_1 {\n            set_debug_loc(\"bumped_by_entity\", 0, 2); set_attr( \"visible\",  false);\n            set_debug_loc(\"bumped_by_entity\", 0, 3); set_attr( \"blocking\",  false);\n            set_debug_loc(\"bumped_by_entity\", 0, 4); notify_in( 2,  \"close_gate\");\n        }\n        else{\n            set_debug_loc(\"bumped_by_entity\", 0, 6); message( value,  \"You need a golden key!\",  \"warning\");\n        }\n    }\n    if event == \"close_gate\" {\n        mark_debug_header(\"close_gate\");\n        set_debug_loc(\"close_gate\", 2, 0); let entities = entities_in_radius();\n        set_debug_value(\"close_gate\", 0, 0, entities);\n        let __cgfx_cond_0_1 = entities.count == 0;\n        set_debug_condition(\"close_gate\", 0, 1, __cgfx_cond_0_1);\n        if __cgfx_cond_0_1 {\n            set_debug_loc(\"close_gate\", 0, 2); set_attr( \"visible\",  true);\n            set_debug_loc(\"close_gate\", 0, 3); set_attr( \"blocking\",  true);\n        }\n        else{\n            set_debug_loc(\"close_gate\", 0, 5); notify_in( 2,  \"close_gate\");\n        }\n    }\n}\n\n","data":"[attributes]\nname = \"Locked Gate\"\ntile_id = \"fe7d9322-4f56-4585-bed9-ae00b747fdc5\"\n\nvisible = true\nstatic = true\nblocking = true\nradius = 0.5\n\n","authoring":"title = \"Gate\"\ndescription = \"\"\"\nA heavy gate bars the way onward.\n\"\"\"\n\n[state.off]\ndescription = \"\"\"\nThe gate is closed and firmly locked.\n\"\"\"\n\n[state.on]\ndescription = \"\"\"\nThe gate stands open, allowing passage beyond.\n\"\"\"\n","position":{"x":0.0,"y":0.0,"z":0.0},"item_id":"05da54c5-4eb9-485f-bb95-03010bdb4b30"},"032cbdaa-e506-46bd-b827-af1f064103d3":{"id":"032cbdaa-e506-46bd-b827-af1f064103d3","name":"Sign","map":{"id":"72b98000-d1b1-42c9-b51d-08b0af444f98","name":"New Map","offset":{"x":0.0,"y":0.0},"grid_size":30.0,"subdivisions":1.0,"dungeon":{"active_layer":0,"layers":[]},"vertices":[],"linedefs":[],"sectors":[],"sky_texture":null,"camera":"TwoD","lights":[],"entities":[],"items":[],"selected_vertices":[],"selected_linedefs":[],"selected_sectors":[],"selected_entity_item":null,"properties":{"values":{}},"softrigs":{},"surfaces":{},"terrain_organic_layer":{"id":"8ee254eb-5e78-4a96-87d6-01ad3ba53520","name":"Main Organic Layer","cell_size":0.05,"page_size":16,"pages":{},"channel_bindings":[{"channel":0,"name":"Foliage","source":null,"roughness":0.5,"metallic":0.0,"opacity":1.0,"emissive":0.0},{