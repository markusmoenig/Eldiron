le.\nshadow_enabled = true\n\n# Shadow strength (default 0.8).\nshadow_strength = 0.8\n\n# Shadow-map resolution.\nshadow_resolution = 1024\n\n# Shadow depth bias.\nshadow_bias = 0.0015\n\n# Fade mode for alpha/visibility transitions: \"ordered_dither\" or \"uniform\".\nfade_mode = \"ordered_dither\"\n\n# Static sky color (used when simulation is disabled)\nsky_color = \"#87CEEB\"\n\n# Static sun color (used when simulation is disabled)\nsun_color = \"#FFFACD\"\n\n# Sun intensity/brightness multiplier\nsun_intensity = 1.5\n\n# Static sun direction as [x, y, z] (used when simulation is disabled)\nsun_direction = [-0.5, -1.0, -0.3]\n\n# Enable/disable sun lighting\nsun_enabled = true\n\n# Ambient light color\nambient_color = \"#999999\"\n\n# Ambient light strength (0.0 - 1.0)\nambient_strength = 0.2\n\n# Fog color\nfog_color = \"#808080\"\n\n# Fog density (0.0 = no fog, higher values = denser fog)\nfog_density = 0.0\n\n# Avatar readability boost toggle (Raster 3D avatars/billboards).\navatar_highlight_enabled = true\n# Avatar readability lift multiplier (1.0 = unchanged).\navatar_highlight_lift = 2.0\n# Avatar ambient fill contribution.\navatar_highlight_fill = 1.20\n# Avatar rim-light contribution.\navatar_highlight_rim = 0.18\n\n[post]\n# Enable/disable final post pass.\nenabled = true\n# Tone mapper: \"none\", \"reinhard\", \"aces\".\ntone_mapper = \"reinhard\"\n# Exposure multiplier before tone mapping.\nexposure = 1.5\n# Post saturation (1.0 = unchanged, 0.0 = grayscale).\nsaturation = 1.0\n# Post luminance/brightness multiplier.\nluminance = 1.0\n# Output gamma.\ngamma = 2.2\n# Stylized grain/noise amount (0 = off, 1 = strong).\ngrit = 0.4\n# Stylized tonal banding amount (0 = off, 1 = strong).\nposterize = 0.4\n# Bias colors toward earthy retro tones (0 = off, 1 = strong).\npalette_bias = 0.7\n# Lift near-black areas after tone mapping (0 = off, 1 = strong).\nshadow_lift = 0.0\n# Soften harsh post contrast (0 = off, 1 = strong).\nedge_soften = 0.0\n\n\n[simulation]\n# Enable procedural daylight simulation (overrides static sky_color, sun_color, sun_direction)\nenabled = true\n\n# Sky color at night (dark)\nnight_sky_color = \"#555555\"\n\n# Sky color at sunrise/sunset (morning)\nmorning_sky_color = \"#FF9966\"\n\n# Sky color at midday\nmidday_sky_color = \"#ffffff\"\n\n# Sky color in the evening\nevening_sky_color = \"#FF8040\"\n\n# Sun/moon color at night (very dim)\nnight_sun_color = \"#1A1A26\"\n\n# Sun color at sunrise/sunset (morning)\nmorning_sun_color = \"#FFCC99\"\n\n# Sun color at midday\nmidday_sun_color = \"#FFFFF2\"\n\n# Sun color in the evening\nevening_sun_color = \"#FFB380\"\n\n# Sunrise time in 24-hour format (e.g., 6.5 = 6:30 AM)\nsunrise_time = 6.0\n\n# Sunset time in 24-hour format (e.g., 18.5 = 6:30 PM)\nsunset_time = 18.0\n\n","world_module":{"id":"42d26ac0-2647-4b3e-94a0-fe691eff0e58","module_type":"World","name":"","routines":{"4e6517b9-81d1-468e-af6e-517a67a7876b":{"id":"4e6517b9-81d1-468e-af6e-517a67a7876b","name":"dungeon_exit","module_offset":0,"visible":true,"folded":false,"pixelization":0,"scale":1.0,"rotation":0.0,"color_steps":0,"screen_width":688,"grid":{"grid":[[[0,0],{"id":"7c5c11c2-7b1b-4f33-9b81-62c5f5f0d001","cell":"BuildProcedural","has_error":false,"dependend_on":null,"replaceable":true,"description":"","form":"LeftRounded","option":0,"special_role":"None"}],[[1,1],{"id":"1b13da65-f249-418c-8bcd-967fdef5d21c","cell":{"Value":"value"},"has_error":false,"dependend_on":"1fbeaf62-90b6-4f81-a71e-27156da08168","replaceable":true,"description":"Entity ID","form":"Box","option":0,"special_role":"None"}],[[3,1],{"id":"f16ea4de-7bd1-46f8-8a78-60cf1855856c","cell":{"Value":"\"\""},"has_error":false,"dependend_on":"1fbeaf62-90b6-4f81-a71e-27156da08168","replaceable":true,"description":"Region Name","form":"RightRounded","option":0,"special_role":"None"}],[[0,1],{"id":"1fbeaf62-90b6-4f81-a71e-27156da08168","cell":"TeleportEntity","has_error":false,"dependend_on":null,"replaceable":true,"description":"","form":"LeftRounded","option":0,"special_role":"None"}],[[1,0],{"id":"7c5c11c2-7b1b-4f33-9b81-62c5f5f0d002","cell":{"Value":"0"},"has_error":false,"dependend_on":"7c5c11c2-7b1b-4f33-9b81-62c5f5f0d001","replaceable":true,"description":"Seed","form":"RightRounded","option":0,"special_role":"None"}],[[2,1],{"id":"9179e2d9-06ee-4200-a187-e6a056b4c983","cell":{"Value":"\"entrance\""},"has_error":false,"dependend_on":"1fbeaf62-90b6-4f81-a71e-27156da08168","replaceable":true,"description":"Sector Name","form":"Box","option":0,"special_role":"None"}]],"grid_rects":[],"row_indents":[[0,0],[1,0]]}}},"player":false,"view_name":"","filter_text":""},"world_source":"fn event(event, value) {\n    if event == \"dungeon_exit\" {\n        build_procedural( 0);\n        teleport_entity( value,  \"entrance\",  \"\");\n    }\n}\n\n","world_source_debug":"fn event(event, value) {\n    if event == \"dungeon_exit\" {\n        mark_debug_header(\"dungeon_exit\");\n        set_debug_loc(\"dungeon_exit\", 0, 0); build_procedural( 0);\n        set_debug_loc(\"dungeon_exit\", 0, 1); teleport_entity( value,  \"entrance\",  \"\");\n    }\n}\n\n","rules":"# value = base damage\n# attacker.<attr> / defender.<attr> = character attributes\n# weapon.<attr> = attacker's equipped weapon attributes\n# source.<attr> = the actual weapon or spell item used for the hit\n# Kind overrides live under [combat.kinds.<kind>]\n# Optional auto-messages live under [combat.messages]\n# Optional player combat audio lives under [combat.audio]\n# Progression stats live under [progression.<stat>]\n\n[progression.damage]\nbase = 1\ngain = \"STR * 0.25\"\n\n[progression.level]\nxp_for_level = \"level * 25\"\n\n[progression.xp]\nkill = \"defender.LEVEL * 50\"\n\n[progression.messages]\nxp_key = \"progression.xp.gained\"\nxp_category = \"system\"\nlevel_up_key = \"progression.level_up\"\nlevel_up_category = \"system\"\n\n[combat]\noutgoing_damage = \"value + source.DMG\"\nincoming_damage = \"value + attacker.STR - defender.ARMOR\"\n\n[combat.messages]\nincoming_key = \"combat.damage.incoming\"\nincoming_category = \"warning\"\noutgoing_key = \"combat.damage.outgoing\"\noutgoing_category = \"system\"\n\n[combat.audio]\nincoming_fx = \"hit\"\nincoming_bus = \"sfx\"\nincoming_gain = 1.0\noutgoing_fx = \"attack\"\noutgoing_bus = \"sfx\"\noutgoing_gain = 1.0\n\n[combat.kinds.physical]\noutgoing_damage = \"value + source.DMG\"\nincoming_damage = \"value + attacker.STR - defender.ARMOR\"\n\n[combat.kinds.spell]\noutgoing_damage = \"value + source.POWER\"\nincoming_damage = \"value + attacker.INT - defender.RESIST\"\n\n[combat.kinds.spell.audio]\nincoming_fx = \"hit\"\noutgoing_fx = \"arcane_cast\"\n\n[combat.kinds.fire]\noutgoing_damage = \"value + source.POWER\"\nincoming_damage = \"value + attacker.INT - defender.FIRE_RESIST\"\n\n[combat.kinds.fire.audio]\nincoming_fx = \"hit\"\noutgoing_fx = \"fire_cast\"\n\n","locales":"[en]\ncombat.damage.incoming = \"{attacker} hits you for {amount} damage\"\ncombat.damage.outgoing = \"You hit {defender} for {amount} damage\"\nprogression.xp.gained = \"You gain {amount} XP\"\nprogression.level_up = \"You reached level {level}\"\nsystem.too_far_away = \"Too far away\"\nsystem.cant_do_that = \"Can't do that\"\nsystem.cant_do_that_yet = \"Can't do that yet\"\nsystem.cant_afford = \"You can't afford that\"\nsystem.you_bought = \"You bought\"\nsystem.exit_menu = \"Goodbye\"\n","audio_fx":"[sfx.door_open]\nwave = \"noise\"\nduration = 0.12\nattack = 0.002\ndecay = 0.10\nrelease = 0.02\ngain = 0.35\nfreq = 900\nfreq_end = 280\nnoise = 0.85\nlowpass = 0.45\n\n[sfx.door_close]\nwave = \"noise\"\nduration = 0.10\nattack = 0.0\ndecay = 0.08\nrelease = 0.02\ngain = 0.28\nfreq = 420\nfreq_end = 180\nnoise = 0.75\nlowpass = 0.60\n\n[sfx.fire_cast]\nwave = \"sine\"\nduration = 0.22\nattack = 0.005\ndecay = 0.14\nrelease = 0.03\ngain = 0.30\nfreq = 1200\nfreq_end = 260\nnoise = 0.35\nlowpass = 0.18\n\n[sfx.ice_cast]\nwave = \"triangle\"\nduration = 0.20\nattack = 0.003\ndecay = 0.12\nrelease = 0.03\ngain = 0.25\nfreq = 1400\nfreq_end = 500\nnoise = 0.10\nlowpass = 0.08\n\n[sfx.arcane_cast]\nwave = \"saw\"\nduration = 0.24\nattack = 0.004\ndecay = 0.16\nrelease = 0.04\ngain = 0.22\nfreq = 620\nfreq_end = 1240\nnoise = 0.08\ntremolo_depth = 0.20\ntremolo_freq = 22\n\n[sfx.ui_click]\nwave = \"square\"\nduration = 0.03\nattack = 0.0\ndecay = 0.02\nrelease = 0.01\ngain = 0.16\nfreq = 1200\nfreq_end = 900\n\n[sfx.ui_confirm]\nwave = \"sine\"\nduration = 0.07\nattack = 0.0\ndecay = 0.05\nrelease = 0.02\ngain = 0.18\nfreq = 720\nfreq_end = 1020\n\n[sfx.pickup_coin]\nwave = \"sine\"\nduration = 0.09\nattack = 0.0\ndecay = 0.05\nrelease = 0.02\ngain = 0.18\nfreq = 900\nfreq_end = 1600\nrepeat = 2\nrepeat_gap = 0.02\n\n[sfx.hit_small]\nwave = \"square\"\nduration = 0.08\nattack = 0.0\ndecay = 0.05\nrelease = 0.01\ngain = 0.25\nfreq = 240\nfreq_end = 120\nnoise = 0.15\n\n[sfx.attack]\nwave = \"noise\"\nduration = 0.11\nattack = 0.0\ndecay = 0.07\nrelease = 0.02\ngain = 0.22\nfreq = 1100\nfreq_end = 260\nnoise = 0.92\nlowpass = 0.18\n\n[sfx.hit]\nwave = \"square\"\nduration = 0.09\nattack = 0.0\ndecay = 0.06\nrelease = 0.02\ngain = 0.30\nfreq = 220\nfreq_end = 90\nnoise = 0.18\nlowpass = 0.22\n\n[sfx.hit_heavy]\nwave = \"square\"\nduration = 0.12\nattack = 0.0\ndecay = 0.08\nrelease = 0.02\ngain = 0.34\nfreq = 180\nfreq_end = 70\nnoise = 0.22\nlowpass = 0.25\n\n[sfx.whoosh_small]\nwave = \"noise\"\nduration = 0.10\nattack = 0.0\ndecay = 0.07\nrelease = 0.02\ngain = 0.20\nfreq = 1200\nfreq_end = 380\nnoise = 0.95\nlowpass = 0.15\n\n[sfx.whoosh_large]\nwave = \"noise\"\nduration = 0.18\nattack = 0.0\ndecay = 0.12\nrelease = 0.03\ngain = 0.28\nfreq = 900\nfreq_end = 180\nnoise = 1.0\nlowpass = 0.35\n","authoring":"[startup]\n# Optional welcome text shown before any room text.\nwelcome = \"Welcome to the Hideout Example!\"\n\n# What to show when the game starts in text-style clients:\n# \"description\" = only the current sector description\n# \"room\"        = full room summary\n# \"none\"        = show nothing automatically\nshow = \"room\"\n\n[exits]\n# How exits are shown in text-style clients:\n# \"list\"     = one exit per line\n# \"sentence\" = prose like \"You see a path to the crossroads to the north.\"\nstyle = \"sentence\"\n\n[text.stats]\ntext = \"\"\"\nSTR:\\t{PLAYER.STR}\\tDEX:\\t{PLAYER.DEX}\nHP:\\t{PLAYER.HP}\\tG:\\t{PLAYER.FUNDS}\nEXP:\\t{PLAYER.EXP}\\tLEVEL:\\t{PLAYER.LEVEL}\n\"\"\"\n\n[colors]\ntitle = \"cyan\"\nobjects = \"white\"\nitems = \"bright_magenta\"\ncharacters = \"blue\"\ncorpses = \"bright_black\"\n\n[[colors.character_rules]]\nwhen = \"ALIGNMENT < 0\"\ncolor = \"red\"\n\n[[colors.character_rules]]\nwhen = \"ALIGNMENT > 0\"\ncolor = \"bright_green\"\n\n[colors.message_categories]\nsuccess = \"bright_green\"\nwarning = \"bright_yellow\"\nsevere = \"bright_red\"\nerror = \"bright_red\"\nsystem = \"bright_white\"\nmultiple_choice = \"bright_magenta\"\n\n\n[alias]\n# Terminal command aliases for configured intents.\nattack = [\"hit\", \"kill\"]\n\n[combat]\n# Auto-attack mode for text-style clients:\n# \"never\"     = only attack when explicitly commanded\n# \"on_attack\" = automatically retaliate against the attacker while the fight continues\nauto_attack = \"never\"\n\n[sector_messages]\n# Sector descriptions sent to players when entering a sector.\n# mode_* can be \"always\", \"once\", \"cooldown\", or \"never\".\nmode_2d = \"once\"\nmode_3d = \"always\"\n\n# If mode is \"cooldown\", wait this many in-game minutes before showing\n# the same sector description again.\ncooldown_minutes_2d = 10\ncooldown_minutes_3d = 10\n\n# Whether the starting sector may also show its description automatically.\nshow_on_startup = true\n","avatars":{},"palette_materials":[{"roughness":0.5,"metallic":0.0,"opacity":1.0,"emissive":0.0},{"roughness":0.5,"metallic":0.0,"opacity":1.0,"emissive":0.0},{"roughness":0.5,"metallic":0.0,"opacity":1.0,"emissive":0.0},{"roughness":0.5,"metallic":0.0,"opac