\n            set_tile( \"05ab6adc-1631-4ed2-9857-f85820a7f1ad\");\n        }\n    }\n    if event == \"intent\" {\n        let intent = value.string;\n        let distance = value.distance;\n        if intent == \"use\" {\n            if value.distance > 2 {\n                message( value.subject_id,  \"{too_far_away}\",  \"warning\");\n            }\n            else{\n                toggle_attr( \"active\");\n                block_events( 1,  \"intent\");\n            }\n        }\n    }\n}\n\n","source_debug":"fn event(event, value) {\n    if event == \"startup\" {\n        mark_debug_header(\"startup\");\n    }\n    if event == \"active\" {\n        mark_debug_header(\"active\");\n        set_debug_loc(\"active\", 0, 0); set_emit_light( value);\n        let __cgfx_cond_0_1 = value == true;\n        set_debug_condition(\"active\", 0, 1, __cgfx_cond_0_1);\n        if __cgfx_cond_0_1 {\n            set_debug_loc(\"active\", 0, 2); set_tile( \"f76473d1-70f6-4649-8b0d-cbac627f93d8\");\n        }\n        else{\n            set_debug_loc(\"active\", 0, 4); set_tile( \"05ab6adc-1631-4ed2-9857-f85820a7f1ad\");\n        }\n    }\n    if event == \"intent\" {\n        mark_debug_header(\"intent\");\n        let intent = value.string;\n        let distance = value.distance;\n        let __cgfx_cond_0_0 = intent == \"use\";\n        set_debug_condition(\"intent\", 0, 0, __cgfx_cond_0_0);\n        if __cgfx_cond_0_0 {\n            let __cgfx_cond_0_1 = value.distance > 2;\n            set_debug_condition(\"intent\", 0, 1, __cgfx_cond_0_1);\n            if __cgfx_cond_0_1 {\n                set_debug_loc(\"intent\", 0, 2); message( value.subject_id,  \"{too_far_away}\",  \"warning\");\n            }\n            else{\n                set_debug_loc(\"intent\", 0, 4); toggle_attr( \"active\");\n                set_debug_loc(\"intent\", 0, 5); block_events( 1,  \"intent\");\n            }\n        }\n    }\n}\n\n","data":"[attributes]\n\n# Set the tile ID for the item's sprite\ntile_id = \"05ab6adc-1631-4ed2-9857-f85820a7f1ad\"\n\nname = \"Torch\"\nactive = false\n\nvisible = true\nstatic = false\nblocking = false\nradius = 0.5\nworth = 1\nmonetary = false\n\n[light]\nstrength = 5.0\nrange = 3.0\nflicker = 0.4\n","authoring":"title = \"Torch\"\ndescription = \"\"\"\nA simple hand torch with an iron bracket and a rag-wrapped head.\n\"\"\"\n\n[state.off]\ndescription = \"\"\"\nAn unlit torch rests here, cold and dark.\n\"\"\"\non_use = \"You light the torch.\"\n\n[state.on]\ndescription = \"\"\"\nA lit torch burns with a wavering flame, pushing back the shadows.\n\"\"\"\non_use = \"You extinguish the torch.\"\n","position":{"x":0.0,"y":0.0,"z":0.0},"item_id":"a00086b1-673b-4da0-93a9-78dcad256c38"}},"screens":{"bae1957d-5233-4ad4-a538-f743ca4af4ef":{"id":"bae1957d-5233-4ad4-a538-f743ca4af4ef","name":"Game","map":{"id":"595947f6-9879-4dfd-8b7a-3510bdac7f42","name":"Game","offset":{"x":-277.42502,"y":65.25},"grid_size":27.0,"subdivisions":4.0,"dungeon":{"active_layer":0,"layers":[]},"vertices":[{"id":0,"name":"","x":-14.966667,"y":-8.25,"z":0.0,"properties":{"values":{}}},{"id":1,"name":"","x":5.25,"y":-8.25,"z":0.0,"properties":{"values":{}}},{"id":2,"name":"","x":5.25,"y":8.333333,"z":0.0,"properties":{"values":{}}},{"id":3,"name":"","x":-14.966667,"y":8.333333,"z":0.0,"properties":{"values":{}}},{"id":4,"name":"","x":-12.5,"y":3.4999995,"z":0.0,"properties":{"values":{}}},{"id":5,"name":"","x":-11.0,"y":3.4999995,"z":0.0,"properties":{"values":{}}},{"id":6,"name":"","x":-11.0,"y":4.9999995,"z":0.0,"properties":{"values":{}}},{"id":7,"name":"","x":-12.5,"y":4.9999995,"z":0.0,"properties":{"values":{}}},{"id":48,"name":"","x":6.1499996,"y":-2.9166665,"z":0.0,"properties":{"values":{}}},{"id":49,"name":"","x":14.400001,"y":-2.9166665,"z":0.0,"properties":{"values":{}}},{"id":50,"name":"","x":14.400001,"y":7.75,"z":0.0,"properties":{"values":{}}},{"id":51,"name":"","x":6.1499996,"y":7.75,"z":0.0,"properties":{"values":{}}},{"id":52,"name":""